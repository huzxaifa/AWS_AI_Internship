ts:[{modulePath:"core/src/lib/events/directCall.js",settings:{identifier:"digitalDataComplete"},ruleOrder:50}],conditions:[{modulePath:"core/src/lib/conditions/valueComparison.js",settings:{comparison:{operator:"isTrue"},leftOperand:"%Condition:Enable Google AdWords Conversion%"},timeout:2e3}],actions:[{modulePath:"core/src/lib/actions/customCode.js",settings:{global:!0,source:"https://assets.adobedtm.com/0f2de1d5b89a/565c2aeb0d39/ff65f0a77bc1/RCd07ca68516e7436e9a778592be7ac867-source.min.js",language:"javascript",isExternal:!0},timeout:2e3,delayNext:!0}]},{id:"RL8619392a37554c29bb8326f966e1a0c5",name:"TrustArc Cookie Consent Management",events:[{modulePath:"core/src/lib/events/libraryLoaded.js",settings:{},ruleOrder:1},{modulePath:"data-layer-manager-search-discovery/src/lib/events/data_layer_push_event.js",settings:{eventType:"consentSelection",eventNames:[],subscription:null},ruleOrder:1}],conditions:[],actions:[{modulePath:"core/src/lib/actions/customCode.js",settings:{global:!1,source:'function logConsentTable() {\n    const tableData = [\n        { Key: "Functional Is Enabled", Value: _satellite.getVar("Functional Is Enabled") },\n        { Key: "Personalization Is Enabled", Value: _satellite.getVar("Personalization Is Enabled") },\n        { Key: "Functional Is Enabled - Web SDK", Value: _satellite.getVar("Functional Is Enabled - Web SDK") }\n    ];\n\n    let tableString = "### Consent: Adobe Launch Consent Data Elements\\n";\n    tableData.forEach(row => {\n        tableString += `${row.Key}\\t: ${row.Value}\\n`;\n    });\n\n    _satellite.logger.log(tableString);\n}\n\nfunction getConsentPayload(event) {\n    _satellite.logger.log("### Consent: event.type: ", event.$type);\n    var cookieConsentBehavior, privacySettings, cookieNotice;\n    cookieNotice = _satellite.getVar("Consent | trustArcCookiePref") || "";\n    if (event.$type === "core.library-loaded") {\n        cookieConsentBehavior = _satellite.getVar("Local Storage | cookieConsentBehavior");\n        privacySettings = _satellite.getVar("Local Storage | privacySettings");\n    } else if (event.$type === "data-layer-manager-search-discovery.data-layer-push-event") {\n        cookieConsentBehavior = event.detail._ibm.user.cookieConsentBehavior;\n        privacySettings = event.detail._ibm.user.privacySettings;\n    }\n    _satellite.logger.log("### Consent: cookieNotice: ", cookieNotice, " cookieConsentBehavior: ", cookieConsentBehavior, " privacySettings:", privacySettings);\n    return { cookieNotice: cookieNotice, cookieConsentBehavior: cookieConsentBehavior, privacySettings: privacySettings };\n}\n\nfunction checkConsent(event) {\n    const consent = getConsentPayload(event);\n    var personalization = false, functional = false, adobeTrack = "pending";\n\n    if (consent.cookieNotice === "") {\n        if (consent.cookieConsentBehavior == "implied") {\n            adobeTrack = "in";\n            functional = true;\n            personalization = true;\n            if (consent.privacySettings === "1:"){\n                adobeTrack = "in";\n                functional = true;\n                personalization = false;\n            } else if (consent.privacySettings === "2:") {\n                adobeTrack = "in";\n                functional = true;\n                personalization = true;\n            } else if (consent.privacySettings === "0:") {\n                adobeTrack = "out"; // safer fallback for required-only\n                functional = false;\n                personalization = false;\n            }\n        } else if (consent.cookieConsentBehavior === "expressed") {\n            adobeTrack = "pending"; // EU: waiting for user choice\n            functional = false;\n            personalization = false;\n        }\n    } else {\n        // Cookie preference exists (user made a choice)\n        if (consent.privacySettings === "1:") {\n            adobeTrack = "in";\n            functional = true;\n            personalization = false;\n        } else if (consent.privacySettings === "2:") {\n            adobeTrack = "in";\n            functional = true;\n            personalization = true;\n        } else if (consent.privacySettings === "0:") {\n            adobeTrack = "out";\n            functional = false;\n            personalization = false;\n        }\n    }\n    \n    _satellite.setVar("Personalization Is Enabled", personalization);\n    _satellite.setVar("Functional Is Enabled", functional);\n    _satellite.setVar("Functional Is Enabled - Web SDK", adobeTrack);\n    _satellite.track("setConsent", { "personalization": personalization, "functional": functional });\n    \n    logConsentTable();\n}\n\ncheckConsent(event);',language:"javascript"}},{modulePath:"adobe-alloy/dist/lib/actions/setConsent/index.js",settings:{consent:[{value:{general:"%Functional Is Enabled - Web SDK%"},version:"1.0",standard:"Adobe"}],instanceName:"alloy"},timeout:2e3,delayNext:!0}]},{id:"RL87b2cb653919499186f3aae7c063bb37",name:"Video Complete | [WebSDK]-[Global]",events:[{modulePath:"data-layer-manager-search-discovery/src/lib/events/data_layer_push_event.js",settings:{eventType:"videoComplete",eventNames:[],subscription:null},ruleOrder:50}],conditions:[{modulePath:"core/src/lib/conditions/queryStringParameter.js",settings:{name:"lnk",queryParams:[{value:"L0G"}]},negate:!0,timeout:2e3},{modulePath:"core/src/lib/conditions/customCode.js",settings:{source:function(){return _satellite.logger.log("videoName: "+_satellite.getVar("ACDL._ibm.video.videoName")),_satellite.getVar("ACDL._ibm.video.videoName").trim().length>0}},timeout:2e3}],actions:[{modulePath:"adobe-alloy/dist/lib/actions/updateVariable/index.js",settings:{data:{web:{webInteraction:{type:"other"},webPageDetails:{name:"%Web Page Details Name (AA)%",siteSection:"%Web Page Details Site Section (AA)%"}},_ibm:{video:"%ACDL._ibm.video%"},_experience:{analytics:{event1to100:{event44:{value:1}},customDimensions:{eVars:{eVar8:"%Previous URL (AA)%",eVar50:"%ACDL video publish date%",